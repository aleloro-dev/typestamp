{
  "name": "typestamp-web",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "bun build ../packages/tracker/src/index.ts --outfile public/tracker.js --format esm",
    "dev": "bun run build && bun run --watch src/index.ts",
    "start": "bun run build && bun run src/index.ts"
  },
  "dependencies": {
    "@typestamp/tracker": "workspace:*",
    "@elysiajs/static": "latest",
    "elysia": "latest",
    "elysia-rate-limit": "^4.5.1",
    "nanoid": "latest",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11"
  }
}
