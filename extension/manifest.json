{
  "manifest_version": 3,
  "name": "Typestamp",
  "version": "0.1.0",
  "description": "Prove the effort behind your writing on any website.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Typestamp"
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "permissions": ["activeTab"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ]
}
